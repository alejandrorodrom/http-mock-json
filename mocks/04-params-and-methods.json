          "name": "BrandsList",
          "statusCode": "200",
          "body": {
            "example": "data1"
          }
        },
        {
          "name": "BrandsList2",
          "statusCode": "200",
          "body": {
            "example": "data2"
          }
        },
        {
          "name": "BrandsList3",
          "statusCode": "200",
          "body": {
            "example": "data3"
          }
        }
      ]
    }
  },
  "api/products/:productId/reviews/:reviewId": {
    "GET": {
      "nameResponse": "found",
      "responses": [
        {
          "name": "found",
          "statusCode": 200,
          "body": {
            "productId": 10,
            "reviewId": 3,
            "rating": 5,
            "comment": "Excellent"
          }
        }
